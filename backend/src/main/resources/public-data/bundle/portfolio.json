  "projects": [
    {
      "id": "sql-audit-project",
      "code": "P-01",
      "slug": "sql-audit",
      "title": "SQL 审计与故障排查工具",
      "summary": "把分散在远程服务器上的 SQL 日志检索、结果追溯和归档流程整合为可复用的内部工具。",
      "background": "原有排查依赖固定服务器与固定目录，新增环境需要修改代码，查询过程耗时且结果不易复用。项目需要在不开放任意服务器和路径输入的前提下，提高日志检索、定位和追溯效率。",
      "responsibilities": [
        "主导核心功能和多轮迭代，从既有固定路径查询扩展到可配置的多目标路由。",
        "完成异步查询、任务状态恢复与取消、WebSocket 状态推送和轮询降级的体验优化。",
        "完成动态来源结果、Excel 导出、结果归档、条件复用和软删除等闭环能力。",
        "补充路径边界、输入限制和 SQL 注入相关验证，并完成打包、部署备份与使用文档。"
      ],
      "solution": "后端以查询目标、SSH 连接和日志来源路由构成统一配置模型，优先读取数据库配置并用 properties 兜底。查询以异步任务执行，结果按来源动态分组；前端优先接收 WebSocket 进度，连接异常时退化为状态轮询。成功结果可以导出或归档，历史归档可以查看并复用查询条件。",
      "keyDecisions": [
        "用目标、连接和来源路由替代服务器与目录硬编码，同时禁止用户输入任意主机和路径。",
        "把动态 sourceResults 作为唯一真实结果，旧固定字段只作为短期兼容派生。",
        "WebSocket 正常时避免固定轮询，断开或长时间无消息时使用状态查询兜底。",
        "允许截断结果归档，但显式记录截断状态，避免把部分结果误认为完整结果。"
      ],
      "technologies": [
        "Java",
        "Spring Boot",
        "Vue",
        "SSH",
        "WebSocket",
        "MySQL",
        "Excel 导出"
      ],
      "verification": [
        "逐项验证时间排序、完整 SQL 展示、动态来源、导出、归档、复用和软删除。",
        "验证 WebSocket 断开后的轮询降级，以及页面刷新后的任务状态恢复。",
        "测试关键字输入、路径安全和 SQL 注入相关边界，并记录仍需兼容的负号场景。",
        "生成可部署 JAR，部署前备份原制品，并编写面向使用者的完整操作文档。"
      ],
      "outcome": "核心版本已完成、部署并形成使用文档，覆盖查询、实时进度、结果查看、导出、归档和复用等主要流程。",
      "handoff": "本人主导核心功能及多轮迭代，后续部分环境适配和优化由同事继续接手。",
      "status": "DELIVERED",
      "contributionType": "PRIMARY",
