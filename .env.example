# Copy to .env for local development. Never commit real API keys.
#
# Spring Boot reads process environment variables. Load this file through your
# IDE, deployment platform, or shell before starting the application.

# Select exactly one reviewed provider.
PORTFOLIO_MODEL_PROVIDER=DEEPSEEK_V4_FLASH

# Enable only after the deployment owner has approved the applicable data policy.
PORTFOLIO_MODEL_ENABLED=true
PORTFOLIO_MODEL_DATA_POLICY_APPROVED=false
PORTFOLIO_CONVERSATIONAL_AGENT_ENABLED=true
PORTFOLIO_VISITOR_MODEL_DATA_POLICY_APPROVED=false

# Populate only the key for the selected provider.
PORTFOLIO_AGENT_DEEPSEEK_API_KEY=
PORTFOLIO_AGENT_GLM_API_KEY=

# Optional runtime tuning.
PORTFOLIO_MODEL_TIMEOUT=8s
PORTFOLIO_MODEL_MAX_TOKENS=1200
PORTFOLIO_CONVERSATION_MAX_INPUT_TOKENS=12000
